---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { getCollection } from 'astro:content';

const title = 'Médecin Esthétique Casablanca | Dr Yousra El Khadri';
const description = 'Dr Yousra El Khadri, médecin esthétique à Casablanca. Botox, filler, skin booster, laser, hydrafacial. Restylane, Sculptura, Radiesse. Résultats naturels.';

const localBusinessJsonLd = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'Physician'],
  name: 'Dr Yousra El Khadri - Médecine Esthétique',
  image: 'https://dryousra.ma/images/dr-yousra-elkhadri.jpg',
  telephone: '+212660148108',
  email: 'yousra.elkhadri@gmail.com',
  url: 'https://dryousra.ma',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '117 Angle Boulevard 2 Mars, Rue de Rome, Résidence EL HAYAT, 3ème étage',
    addressLocality: 'Casablanca',
    addressCountry: 'MA',
  },
  medicalSpecialty: ['Aesthetic Medicine', 'Anti-Aging Medicine', 'Laser Medicine'],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '19:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '14:00',
    },
  ],
  sameAs: [
    'https://www.instagram.com/dr.yousra.elkhadri/',
    'https://www.tiktok.com/@dryousraelkhadri',
  ],
};

const faqItems = [
  {
    question: "C'est quoi la médecine esthétique ?",
    answer: "La médecine esthétique regroupe les soins médicaux non chirurgicaux qui améliorent l'apparence du visage et du corps. Elle se pratique en cabinet, sans hospitalisation, avec des suites sociales minimes. Botox, fillers, lasers, peelings et stimulateurs de collagène en constituent les piliers principaux.",
  },
  {
    question: 'Botox et filler : quelle différence ?',
    answer: "Le Botox détend les muscles responsables des rides d'expression (front, ride du lion, pattes d'oie). Le filler, à base d'acide hyaluronique, comble les volumes perdus et redessine les contours du visage : lèvres, pommettes, cernes, ovale. Les deux soins se complètent souvent pour un résultat global et harmonieux.",
  },
  {
    question: 'Les soins sont-ils douloureux ?',
    answer: "La très grande majorité des soins esthétiques sont confortables. Les aiguilles utilisées sont ultra-fines, une crème anesthésiante est appliquée lorsque nécessaire, et les fillers contiennent de la lidocaïne. Vous ressentez tout au plus une légère pression ou un picotement bref.",
  },
  {
    question: 'Comment prendre rendez-vous au cabinet ?',
    answer: 'Vous pouvez réserver votre consultation par WhatsApp au +212 6 60 14 81 08, par téléphone au cabinet, ou via les messages Instagram. La première consultation permet de définir vos objectifs et de construire votre protocole personnalisé.',
  },
  {
    question: 'Le cabinet est-il bien situé à Casablanca ?',
    answer: 'Oui. Le cabinet se trouve au 117 Angle Boulevard 2 Mars, Rue de Rome, Résidence EL HAYAT, 3ème étage, au Quartier des Hôpitaux à Casablanca. Un emplacement central, accessible facilement, dans un environnement médical de référence.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.question === 'Les soins sont-ils douloureux ?'
        ? "La très grande majorité des soins esthétiques sont confortables. Les aiguilles sont ultra-fines, une crème anesthésiante est appliquée lorsque nécessaire, et les fillers contiennent de la lidocaïne. Vous ressentez tout au plus une légère pression ou un picotement bref."
        : item.answer,
    },
  })),
};

const latestArticles = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);
const postSlug = (id: string) => id.replace(/\.md$/, '');
---

<BaseLayout {title} {description} canonical="/" jsonLd={[localBusinessJsonLd, faqJsonLd]}>
  <script src="https://elfsightcdn.com/platform.js" async></script>

  <section class="hero" id="hero-sec"><div class="hi">
    <div>
      <div class="hb">Dr Yousra El Khadri · Casablanca</div>
      <h1>Médecin esthétique<br /><em>à Casablanca</em></h1>
      <p class="hd">Au cabinet de Dr Yousra El Khadri, au cœur du Quartier des Hôpitaux à Casablanca, vous bénéficiez d'une médecine esthétique fondée sur des résultats naturels, une rigueur médicale stricte et un accompagnement personnalisé.</p>
      <div class="ha">
        <a href="https://wa.me/212660148108" class="btn bp"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>Prendre rendez-vous</a>
