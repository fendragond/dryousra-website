---
import DetailPageLayout from '../../../layouts/DetailPageLayout.astro';

const title = '<em>Détatouage Laser</em> à Casablanca';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Tous les tatouages peuvent-ils être effacés ?',
      acceptedAnswer: { '@type': 'Answer', text: 'La plupart oui.' },
    },
  ],
};

const faqItems = [
  { question: 'Douloureux ?', answer: 'Picotements chauds atténués par crème anesthésiante.' },
  { question: 'Tous les tatouages ?', answer: 'La plupart. Le noir est le plus facile, les couleurs claires demandent plus de séances.' },
  { question: 'Risque de cicatrice ?', answer: 'Très faible avec les lasers modernes.' },
];

const crossLinks = [
  {
    label: 'Besoins associés',
    links: [
      { text: 'Enlever un tatouage', url: '/besoins/tatouage' },
    ],
  },
  {
    label: 'Autres traitements laser',
    variant: 'rose' as const,
    links: [
      { text: 'Laser médical', url: '/soins/laser/laser-medical' },
    ],
  },
];
---

<DetailPageLayout
  seoTitle="Détatouage Laser à Casablanca | Toutes couleurs | Dr El Khadri"
  description="Détatouage laser à Casablanca par Dr Yousra El Khadri. Effacement progressif et sécurisé des tatouages, toutes couleurs."
  canonical="/soins/laser/detatouage"
  {jsonLd}
  label="Laser"
  {title}
  {faqItems}
  {crossLinks}
  showGalleryCTA
>
  <p>Le laser fractionne les pigments d'encre en micro-particules éliminées naturellement par l'organisme. 4 à 8 séances en moyenne, espacées de 6 à 8 semaines.</p>
  <h2>Déroulement</h2>
  <p>Crème anesthésiante 30 minutes avant. Le laser cible les pigments. Séance de 15 à 30 minutes.</p>
</DetailPageLayout>
