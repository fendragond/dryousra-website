---
import DetailPageLayout from '../../../layouts/DetailPageLayout.astro';
import ZoneCard from '../../../components/ZoneCard.astro';

const title = '<em>Peeling corps</em> à Casablanca';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Combien de séances ?',
      acceptedAnswer: { '@type': 'Answer', text: '4 à 6 séances en moyenne.' },
    },
  ],
};

const faqItems = [
  { question: 'Sécurisé pour les zones intimes ?', answer: 'Oui, peeling spécifiquement formulé pour ces zones sensibles.' },
  { question: 'Combien de séances ?', answer: '4 à 6 séances en moyenne.' },
];

const crossLinks = [
  {
    label: 'Besoins associés',
    links: [
      { text: 'Effacer les taches', url: '/besoins/taches' },
    ],
  },
  {
    label: 'Autres soins du corps',
    variant: 'rose' as const,
    links: [
      { text: 'Lipolyse', url: '/soins/soins-corps/lipolyse' },
    ],
  },
];
---

<DetailPageLayout
  seoTitle="Peeling Corps à Casablanca | Aisselles, Mains | Dr El Khadri"
  description="Peeling corps à Casablanca par Dr Yousra El Khadri. Cou, aisselles, parties intimes, mains. Éclaircissement et uniformisation."
  canonical="/soins/soins-corps/peeling-corps"
  {jsonLd}
  label="Soin du corps"
  {title}
  {faqItems}
  {crossLinks}
  showGalleryCTA
>
  <p>Le peeling corps cible des zones spécifiques sujettes à l'hyperpigmentation : aisselles, parties intimes, mains, cou. Traitement médical d'éclaircissement et d'uniformisation.</p>
  <h2>Zones traitées</h2>
  <div class="zones">
    <ZoneCard title="Aisselles" description="Éclaircissement médical." />
    <ZoneCard title="Parties intimes" description="Éclaircissement discret." />
    <ZoneCard title="Mains" description="Atténuation des taches solaires." />
    <ZoneCard title="Cou" description="Soin éclat." />
  </div>
  <h2>Déroulement</h2>
  <p>Application du peeling adapté à la zone et au phototype. 4 à 6 séances espacées de 3 à 4 semaines.</p>
</DetailPageLayout>
