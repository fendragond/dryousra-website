---
import DetailPageLayout from '../../layouts/DetailPageLayout.astro';

const title = 'Effacer les <em>taches</em>';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Le laser laisse-t-il des marques ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Non avec les technologies actuelles.' },
    },
  ],
};

const faqItems = [
  { question: 'Le laser laisse-t-il des marques ?', answer: 'Non avec les technologies actuelles. Rougeurs temporaires seulement.' },
];

const crossLinks = {
  label: 'Soins recommandés',
  links: [
    { text: 'Laser médical', url: '/soins/laser/laser-medical' },
    { text: 'Peeling', url: '/soins/soins-visage/peeling' },
    { text: 'Hydrafacial', url: '/soins/soins-visage/hydrafacial' },
  ],
};
---

<DetailPageLayout
  seoTitle="Effacer les taches à Casablanca | Dr El Khadri"
  description="Effacer les taches pigmentaires à Casablanca. Laser, peeling, hydrafacial. Solaires, mélasma, taches de vieillesse."
  canonical="/besoins/taches"
  {jsonLd}
  label="Votre besoin"
  {title}
  {faqItems}
  {crossLinks}
  showGalleryCTA
>
  <p>Taches solaires, mélasma, taches de vieillesse, hyperpigmentation post-acné : plusieurs solutions médicales permettent d'unifier le teint.</p>
  <h3>Solutions ciblées</h3>
  <ul>
    <li><strong>Laser pigmentaire</strong> : 3 à 5 séances.</li>
    <li><strong>Peeling médical</strong> : exfolie et accélère le renouvellement cellulaire.</li>
    <li><strong>Hydrafacial</strong> : en complément.</li>
  </ul>
</DetailPageLayout>
