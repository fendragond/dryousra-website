---
import DetailPageLayout from '../../../layouts/DetailPageLayout.astro';
import ProductBox from '../../../components/ProductBox.astro';

const title = '<em>Sculptura</em> à Casablanca';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'En combien de temps voit-on le résultat ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Premiers effets à 6-8 semaines, optimal à 3-6 mois.' },
    },
  ],
};

const faqItems = [
  { question: 'En combien de temps voit-on le résultat ?', answer: 'Premiers effets à 6-8 semaines, optimal à 3-6 mois.' },
  { question: 'Combien de temps durent les effets ?', answer: '2 à 3 ans en moyenne.' },
  { question: "C'est différent du filler ?", answer: "Oui. Le filler comble immédiatement avec de l'acide hyaluronique. Sculptura stimule progressivement votre propre collagène." },
  { question: 'Combien de séances ?', answer: '2 à 3 séances espacées de 4 à 6 semaines.' },
];

const crossLinks = [
  {
    label: 'Besoins associés',
    links: [
      { text: 'Rajeunir le visage', url: '/besoins/rajeunir' },
      { text: 'Améliorer la texture', url: '/besoins/texture' },
    ],
  },
  {
    label: 'Autres traitements de stimulation',
    variant: 'rose' as const,
    links: [
      { text: 'Radiesse', url: '/soins/stimulation-collagene/radiesse' },
      { text: 'Harmonica', url: '/soins/stimulation-collagene/harmonica' },
    ],
  },
];
---

<DetailPageLayout
  seoTitle="Sculptura à Casablanca | Stimulation collagène | Dr El Khadri"
  description="Sculptura à Casablanca par Dr Yousra El Khadri. Stimulation naturelle du collagène avec acide poly-L-lactique de Galderma."
  canonical="/soins/stimulation-collagene/sculptura"
  {jsonLd}
  label="Stimulation collagène"
  {title}
  {faqItems}
  {crossLinks}
  showGalleryCTA
>
  <p>Sculptura est un produit injectable à base d'acide poly-L-lactique qui stimule la production naturelle de collagène par votre peau. Contrairement aux fillers classiques, Sculptura ne comble pas immédiatement : il agit en profondeur pour reconstruire la structure de la peau pendant plusieurs mois.</p>
  <h2>Comment ça fonctionne ?</h2>
  <p>Sculptura est injecté dans le derme profond. L'acide poly-L-lactique stimule les fibroblastes qui synthétisent un nouveau collagène natif. Ce collagène est votre propre tissu, ce qui rend les résultats extrêmement naturels et durables.</p>
  <h2>Indications</h2>
  <ul>
    <li>Relâchement cutané du visage</li>
    <li>Perte de volume liée à l'âge</li>
    <li>Effet creux temporal et jugal</li>
    <li>Qualité de peau dégradée</li>
  </ul>
  <h2>Déroulement</h2>
  <p>Le protocole comprend généralement 2 à 3 séances espacées de 4 à 6 semaines. Un massage de la zone est recommandé pendant 5 jours après la séance.</p>
  <ProductBox title="Produits utilisés" description="Sculptura est fabriqué par <strong>Galderma</strong>, laboratoire de référence en médecine esthétique." />
</DetailPageLayout>
