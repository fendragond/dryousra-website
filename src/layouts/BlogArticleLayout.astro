---
import BaseLayout from './BaseLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CrossLinks from '../components/CrossLinks.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  seoTitle: string;
  description: string;
  canonical: string;
  ogImage: string;
  date: string;
  readingMinutes: number;
  category: string;
  categoryLabel: string;
  isPilier?: boolean;
  pilierLabel?: string;
  heroImage: string;
  heroImageAlt: string;
  heroFigureAlt?: string;
  heroImageTitle?: string;
  heroImageCaption?: string;
  heroImageWidth?: number;
  heroImageHeight?: number;
  ctaText: string;
  faq: { question: string; answer: string }[];
  crossLinks?: { label: string; links: { text: string; url: string }[] };
  jsonLd: any;
}

const {
  title,
  seoTitle,
  description,
  canonical,
  ogImage,
  date,
  readingMinutes,
  category,
  categoryLabel,
  isPilier = false,
  pilierLabel = 'Guide complet',
  heroImage,
  heroImageAlt,
  heroFigureAlt,
  heroImageTitle,
  heroImageCaption,
  heroImageWidth,
  heroImageHeight,
  ctaText,
  faq,
  crossLinks,
  jsonLd,
} = Astro.props;

const months = [
  'janvier',
  'février',
  'mars',
  'avril',
  'mai',
  'juin',
  'juillet',
  'août',
  'septembre',
  'octobre',
  'novembre',
  'décembre',
];
const [year, month, day] = date.split('-');
const formattedDate = `${Number(day)} ${months[Number(month) - 1]} ${year}`;
const schema = typeof jsonLd === 'string' ? JSON.parse(jsonLd) : jsonLd;
const phoneHref = site.phone.mobile.replace(/\s/g, '');
const canonicalPath = canonical.startsWith(site.url) ? canonical.slice(site.url.length) || '/' : canonical;
const articleHeroWidth = heroImageWidth ?? 880;
const articleHeroHeight = heroImageHeight ?? 580;
---

<BaseLayout title={seoTitle} description={description} canonical={canonicalPath} ogImage={ogImage} ogType="article" jsonLd={schema}>
  <section class="blog-article-hero">
    <div class="blog-article-hero-inner rv">
      <span class="blog-article-meta-badge">{categoryLabel}</span>
      {isPilier && <span class={`blog-badge blog-badge-pilier ${category}`}>{pilierLabel}</span>}
      <h1>{title}</h1>
      <div class="blog-article-meta">
        <span>{site.name}</span>
        <span aria-hidden="true">·</span>
        <span>{formattedDate}</span>
        <span aria-hidden="true">·</span>
        <span>{readingMinutes} min de lecture</span>
      </div>
    </div>
  </section>

  {heroImageCaption && (
    <figure class="blog-cabinet-photo rv">
      <img
        src={heroImage}
        alt={heroFigureAlt || heroImageAlt}
        title={heroImageTitle}
        width={articleHeroWidth}
        height={articleHeroHeight}
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
      <figcaption>{heroImageCaption}</figcaption>
    </figure>
  )}

  <section class="sec sec-w blog-article-sec">
    <article class="blog-article">
      <slot />

      <FAQAccordion items={faq} />

      <div class="article-cta-box">
        <h2>Prendre rendez-vous au cabinet de Dr Yousra El Khadri</h2>
        <p set:html={ctaText} />
        <div class="article-cta-links">
          <a href={site.whatsapp.url}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
            WhatsApp
          </a>
          <a href={`tel:${phoneHref}`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2" /></svg>
            {site.phone.mobile}
          </a>
        </div>
        <p class="article-cta-hours">Lundi au vendredi : 9h à 19h &nbsp;·&nbsp; Samedi : 9h à 14h</p>
      </div>

      {crossLinks && <CrossLinks label={crossLinks.label} links={crossLinks.links} />}
    </article>
  </section>
</BaseLayout>
