---
import DetailPageLayout from '../../../layouts/DetailPageLayout.astro';

const title = '<em>Baby Lips</em> à Casablanca';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Différent du filler classique ?',
      acceptedAnswer: { '@type': 'Answer', text: 'Le Baby Lips hydrate, le filler classique apporte du volume.' },
    },
  ],
};

const faqItems = [
  { question: 'Différent du filler classique ?', answer: "Le Baby Lips utilise un acide hyaluronique fluide qui hydrate sans modifier le volume marqué." },
  { question: 'Combien de temps ça dure ?', answer: 'Environ 6 à 9 mois.' },
];

const crossLinks = [
  {
    label: 'Besoins associés',
    links: [
      { text: 'Repulper les lèvres', url: '/besoins/levres' },
    ],
  },
  {
    label: 'Autres soins du visage',
    variant: 'rose' as const,
    links: [
      { text: 'Hydrafacial', url: '/soins/soins-visage/hydrafacial' },
      { text: 'Exosomes', url: '/soins/soins-visage/exosomes' },
    ],
  },
];
---

<DetailPageLayout
  seoTitle="Baby Lips à Casablanca | Soin lèvres pulpeuses | Dr El Khadri"
  description="Baby Lips à Casablanca par Dr Yousra El Khadri. Soin doux et naturel pour des lèvres hydratées et repulpées sans excès de volume."
  canonical="/soins/soins-visage/baby-lips"
  {jsonLd}
  label="Soin du visage"
  {title}
  {faqItems}
  {crossLinks}
  showGalleryCTA
>
  <p>Le Baby Lips combine hydratation profonde et léger repulpage pour un effet lèvres de bébé : douces, hydratées, lumineuses, sans excès de volume.</p>
  <h2>Indications</h2>
  <ul><li>Lèvres déshydratées</li><li>Légère perte de volume</li><li>Recherche d'un effet naturel</li></ul>
  <h2>Déroulement</h2>
  <p>Séance de 15 à 20 minutes sous crème anesthésiante. Aucune éviction sociale.</p>
</DetailPageLayout>
